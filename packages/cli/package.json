{
  "name": "@ignitionai/agent-trainer-cli",
  "version": "0.1.0-alpha.1",
  "description": "Local CLI for running typed Ignition Agent Trainer experiments.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "ignition-agent-trainer": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IgnitionAI/ignition-agent-trainer.git",
    "directory": "packages/cli"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "bun src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@ignitionai/agent-trainer": "0.1.0-alpha.1",
    "@ignitionai/agent-trainer-core": "0.1.0-alpha.1",
    "@ignitionai/agent-trainer-environment": "0.1.0-alpha.1",
    "@ignitionai/agent-trainer-experiments": "0.1.0-alpha.1",
    "@ignitionai/agent-trainer-exporters": "0.1.0-alpha.1",
    "@ignitionai/agent-trainer-rl": "0.1.0-alpha.1"
  },
  "devDependencies": {
    "tsup": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "peerDependencies": {},
  "peerDependenciesMeta": {},
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  }
}
