{
  "name": "@ignitionai/adapter-ignitionrag",
  "version": "0.1.0-alpha.0",
  "description": "Type-level IgnitionRAG adapter contract for Ignition Agent Trainer.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IgnitionAI/ignition-agent-trainer.git",
    "directory": "packages/adapter-ignitionrag"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run"
  },
  "dependencies": {
    "@ignitionai/core": "workspace:*",
    "@ignitionai/exporters": "workspace:*"
  },
  "devDependencies": {
    "tsup": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "peerDependencies": {},
  "peerDependenciesMeta": {}
}
